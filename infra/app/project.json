{
  "name": "infra-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["web"],
  "targets": {
    "build":  { "executor": "nx:run-script", "options": { "script": "build" } },
    "synth":  { "executor": "nx:run-script", "options": { "script": "synth" } },
    "deploy": {
      "executor": "nx:run-script",
      "options": { "script": "deploy" },
      "dependsOn": [{ "projects": ["web"], "target": "opennext-build" }]
    },
    "diff":   { "executor": "nx:run-script", "options": { "script": "diff" } }
  }
}
